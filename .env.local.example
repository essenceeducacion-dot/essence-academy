# ============================================================================
# Essence Academy — Variables de entorno
# Copiar a .env.local y completar. NO commitear .env.local.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Solo en servidor (Server Actions / route handlers). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- App --------------------------------------------------------------------
# URL pública del sitio (links de recuperación de contraseña, verificación de
# certificados, etc.). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Feature flags ----------------------------------------------------------
ENABLE_PAGOS=false
ENABLE_COMUNIDAD=true
ENABLE_CERTIFICADOS=true

# --- Emails transaccionales (Resend) — opcional en desarrollo ---------------
# Si está vacío, la capa lib/email.ts loguea en consola en vez de enviar.
RESEND_API_KEY=
EMAIL_FROM=Essence Academy <no-responder@essence.academy>

# --- Pagos (futuro, NO implementar ahora) -----------------------------------
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=
